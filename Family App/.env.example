# Copy this file to .env and fill in your values.

# ─── App Identity ────────────────────────────────────────
VITE_APP_NAME="Family Hub"
VITE_APP_VERSION="1.0.0"

# ─── Family Config ───────────────────────────────────────
VITE_FAMILY_MEMBERS="mom,dad,stella,roman,layla"

# ─── Storage ─────────────────────────────────────────────
VITE_STORAGE_PREFIX="family_"

# ─── Feature Flags ───────────────────────────────────────
VITE_ENABLE_MEALS=true
VITE_ENABLE_GROCERIES=true
VITE_ENABLE_CUSTODY=true

# ─── Supabase (put in .env, never commit) ────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Secrets (put in .env.local, never commit) ───────────
# VITE_API_URL=
# VITE_PUSH_NOTIFICATION_KEY=
# VITE_GOOGLE_CALENDAR_API_KEY=
