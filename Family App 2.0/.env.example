# Family Hub 2.0 — environment variables
# Copy this file to `.env.local` and populate values. Never commit secrets.

# Supabase project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon (publishable) key — safe to ship in the client bundle.
VITE_SUPABASE_ANON_KEY=

# VAPID public key for Web Push subscriptions. Populated in Phase 6.
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
